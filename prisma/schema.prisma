enum RunWorkflowStatus {
  DEVELOP
  PENDING
  SUBMITTED
  APPROVED
}

enum CityRunType {
  CLUB
  INDIVIDUAL
  RACE_SHAKEOUT
  RUN_CREW
  OTHER
}

/// Synced from GoFastCompany acq_brands (slug bridge).
enum BrandType {
  SHOE
  APPAREL
  RUN_STORE_CHAIN
  GEAR
  OTHER
}

enum RouteShape {
  LOOP
  OUT_AND_BACK
  POINT_TO_POINT
}

enum RouteTerrain {
  FLAT
  ROLLING
  HILLY
  MIXED
}

enum RouteSurface {
  PAVED
  TRAIL
  GRAVEL
  MIXED
}

enum RouteTraffic {
  NO_CARS
  LOW_TRAFFIC
  MODERATE_TRAFFIC
  HIGH_TRAFFIC
}

enum RouteLighting {
  FULLY_LIT
  PARTIALLY_LIT
  UNLIT
}

enum RouteShade {
  FULL_SHADE
  PARTIAL_SHADE
  EXPOSED
}

enum RouteVibe {
  SPEED_WORK
  TEMPO
  LONG_RUN
  RECOVERY
  SOCIAL
  BEGINNER_FRIENDLY
}

// ─── Training Cohorts ─────────────────────────────────────────────────────────
//
// Race-scoped virtual training cohort. Staff seed a preset + optional default
// start date; athletes join and receive individual materialized training_plans.

enum TrainingCohortStatus {
  DRAFT
  OPEN
  ACTIVE
  COMPLETE
}

enum TrainingCohortRole {
  MEMBER
  PACER
  ADMIN
}

model training_cohorts {
  id                   String               @id @default(cuid())
  raceId               String
  companyRaceId        String?
  presetId             String
  cohortName           String
  handle               String               @unique
  description          String?
  logo                 String?
  joinCode             String               @unique
  defaultPlanStartDate DateTime?
  status               TrainingCohortStatus @default(DRAFT)
  companyStaffId       String?
  city                 String?
  state                String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  race_registry            race_registry                 @relation(fields: [raceId], references: [id])
  training_plan_preset     training_plan_preset          @relation(fields: [presetId], references: [id])
  memberships              training_cohort_memberships[]
  training_plans           training_plans[]
  messages                 training_cohort_messages[]
  announcements            training_cohort_announcements[]

  @@index([raceId])
  @@index([companyRaceId])
  @@index([presetId])
  @@index([status])
  @@map("training_cohorts")
}

/// Junction: athlete joined this cohort for this race; links to their built plan.
model training_cohort_memberships {
  id             String             @id @default(cuid())
  cohortId       String
  raceId         String
  athleteId      String
  trainingPlanId String?            @unique
  role           TrainingCohortRole @default(MEMBER)
  joinedAt       DateTime           @default(now())

  cohort        training_cohorts @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  race_registry race_registry    @relation(fields: [raceId], references: [id], onDelete: Cascade)
  Athlete       Athlete          @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  training_plan training_plans?  @relation(fields: [trainingPlanId], references: [id], onDelete: SetNull)

  @@unique([cohortId, athleteId])
  @@index([cohortId])
  @@index([raceId, athleteId])
  @@index([athleteId])
  @@index([trainingPlanId])
  @@map("training_cohort_memberships")
}

model training_cohort_messages {
  id        String   @id @default(cuid())
  cohortId  String
  athleteId String
  content   String
  topic     String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cohort  training_cohorts @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  Athlete Athlete          @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@index([cohortId])
  @@index([athleteId])
  @@map("training_cohort_messages")
}

model training_cohort_announcements {
  id               String   @id @default(cuid())
  cohortId         String
  title            String
  content          String
  staffGeneratedId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  archivedAt       DateTime?

  cohort training_cohorts @relation(fields: [cohortId], references: [id], onDelete: Cascade)

  @@index([cohortId])
  @@index([staffGeneratedId])
  @@map("training_cohort_announcements")
}

// Route/location catalogue. Created manually or auto-seeded from run meetUpPoint/title.
// Raw on creation (just name + citySlug); attributes filled in over time.
model run_locations {
  id          String         @id @default(cuid())
  citySlug    String                               // "dc", "arlington" — same slug pattern as city_runs
  cityId      String?
  cities      cities?        @relation(fields: [cityId], references: [id], onDelete: SetNull)
  name        String                               // "Haines Point", "Custis Trail"
  slug        String         @unique               // auto-generated from name
  runType     String?                              // "park" | "track" | "trail" | "neighborhood"
  shape       RouteShape?
  terrain     RouteTerrain?
  surface     RouteSurface?
  traffic     RouteTraffic?
  lighting    RouteLighting?
  shade       RouteShade?
  vibes       RouteVibe[]    @default([])          // SPEED_WORK, TEMPO, LONG_RUN, etc.
  loopMiles   Float?                               // distance of one loop/segment
  notes       String?                              // editorial: "Fast flat loop. No cars. Speed work venue."
  stravaUrl   String?
  meetUpPoint String?                              // default start/meet-up description
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  city_runs   city_runs[]

  @@index([citySlug])
  @@index([cityId])
  @@index([slug])
  @@map("run_locations")
}
