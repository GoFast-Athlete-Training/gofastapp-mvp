model training_plans {
  id                   String                 @id
  athleteId            String
  raceId               String?
  athleteGoalId        String?
  /// Optional link to the training cohort this plan was created through
  cohortId             String?
  /// Optional link to a training_plan_preset; null = generation uses hardcoded defaults
  presetId             String?
  name                 String
  currentWeeklyMileage Int?
  /// Athlete weekly mileage target (miles); falls back at generation time
  weeklyMileageTarget  Int?
  /// Snapshot of current 5K pace for plan-scoped hydration/comparison
  currentFiveKPace     String?
  /// Goal race finish time, e.g. "2:59:00" (marathon). Drives mpSimulation workouts.
  goalRaceTime         String?
  /// Imprinted goal pace per mile, e.g. "6:52" — derived from goalRaceTime + race distance.
  goalRacePace         String?
  lifecycleStatus      TrainingPlanLifecycle  @default(ACTIVE)
  coachReviewStatus    CoachReviewStatus      @default(DRAFT)
  publishedAt          DateTime?
  /// Company user id who published this plan to the training group
  publishedBy          String?
  startDate            DateTime
  totalWeeks           Int
  /// Phase ranges snapshot: [{ name, startWeek, endWeek }]
  phases               Json?
  /// Canonical schedule freeze-frame: structured [{ weekNumber, days[] }] or legacy { weekNumber, schedule } strings)
  planSchedule         Json?
  /// Derived at generation: approximate week containing peak stimulus (pre-taper macro cycle)
  peakWeekNumber       Int?
  /// 1-based week index where taper macro-cycle begins (last ceil(weeks/4) block start)
  taperStartWeekNumber Int?
  /// Max long-run distance (mi) used when applying volume / rotation
  calculatedLongRunMax Float?
  /// Cycle pool snapshot from last generation: { nCycles, cycleLen, poolMilesByCycle, baseMiles, peakMiles, taperMiles, positionCounts }
  cyclePoolData        Json?
  /// Snapshot from preset at last generation (easy standard miles, min trim, pace offset, weekly buffer)
  easyRunConfig        Json?
  /// Snapshot of preferred training days 1=Mon..7=Sun
  preferredDays        Int[]                  @default([])
  /// Preferred long-run day: 6=Saturday, 7=Sunday (default 6)
  preferredLongRunDow  Int?
  /// User-selected DOWs for quality sessions (1=Mon..7=Sun), max 2 entries
  preferredQualityDays Int[]                  @default([])
  /// Athlete tempo day (1=Mon..7=Sun); null = preset default at generation.
  preferredTempoDow    Int?
  /// Athlete interval day (1=Mon..7=Sun); null = preset default at generation.
  preferredIntervalDow Int?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  planned_workouts     workouts[]
  Athlete              Athlete                @relation(fields: [athleteId], references: [id])
  race_registry        race_registry?         @relation(fields: [raceId], references: [id])
  athlete_goal         AthleteGoal?           @relation(fields: [athleteGoalId], references: [id], onDelete: SetNull)
  pace_adjustment_logs pace_adjustment_log[]
  training_plan_preset training_plan_preset? @relation(fields: [presetId], references: [id])
  training_cohort      training_cohorts?     @relation(fields: [cohortId], references: [id], onDelete: SetNull)
  cohort_membership    training_cohort_memberships?

  @@index([athleteGoalId])
  @@index([athleteId, lifecycleStatus])
  @@index([presetId])
  @@index([cohortId])
}


/// Coach-curated prescriptions: segment-mirrored fields (warmup / work base / cooldown).
/// Pace offsets are sec/mile vs current 5K fitness unless paceAnchor is mpSimulation.
model workout_catalogue {
  id                           String      @id @default(cuid())
  name                         String
  /// Free-text sub-type the user types in the app (not a hardcoded select / DB enum). Services look up by this; `slug` (below) is optional kebab normalisation and fallback.
  runSubType                   String?
  /// URL-safe kebab-case, unique when set — derived or edited for stable joins; use when normalising or matching `runSubType`.
  slug                         String?     @unique
  description                  String?
  workoutType                  WorkoutType
  /// JSON: per-segment pace + distance (mile ladders, block-repeat, interval ladders, etc.)
  segmentPaceDist              Json?
  /// Long-run MP-simulation: shares of total scheduled distance (0–1 each; remainder can be unallocated easy)
  warmupFraction               Float?
  workFraction                 Float?
  cooldownFraction             Float?
  /// Fixed-rep work (Intervals): number of reps.
  workBaseReps                 Int?
  /// Fixed-rep work: meters per rep (e.g. 800).
  workBaseRepMeters            Int?
  recoveryDistanceMeters       Int?
  /// Timed jog between reps (flat ladder / legacy repeats). Seconds; when positive, overrides distance-based recovery when materializing.
  recoveryDurationSeconds      Int?
  warmupMiles                  Float?
  warmupPaceOffsetSecPerMile   Int?
  cooldownMiles                Float?
  cooldownPaceOffsetSecPerMile Int?
  /// Sustained work distance (SpeedDuration / Tempo main block), miles.
  workBaseMiles                Float?
  /// Pace offset for easy / long-easy / tempo sustained block (sec/mi vs 5K anchor).
  workPaceOffsetSecPerMile     Int?
  /// Pace offset for each work rep (sec/mi vs 5K anchor).
  workBasePaceOffsetSecPerMile Int?
  recoveryPaceOffsetSecPerMile Int?
  paceAnchor                   String      @default("currentBuildup")
  /// Legacy: fraction of long run at MP when mpTotalMiles not set.
  mpFraction                   Float?
  mpBlockPosition              String?
  mpBlockProgression           String      @default("flat")
  mpTotalMiles                 Float?
  /// Pace offset for the MP block (sec/mi vs 5K anchor).
  mpPaceOffsetSecPerMile       Int?
  intendedHeartRateZone        String?
  intendedHRBpmLow             Int?
  intendedHRBpmHigh            Int?
  notes                        String?
  /// Optional purpose sentences (AI, manual, CSV); coaching context downstream.
  trainingIntent               String[]    @default([])
  createdAt                    DateTime    @default(now())
  updatedAt                    DateTime    @updatedAt
  workouts                    workouts[]
  long_run_config_positions  long_run_config_position[]
  intervals_config_positions  intervals_config_position[]
  tempo_config_positions      tempo_config_position[]
  easy_config_positions       easy_config_position[]

  @@unique([name, workoutType])
  @@index([workoutType])
}

model workouts {
  id                        String              @id @default(cuid())
  title                     String
  workoutType               WorkoutType
  description               String?
  /// Null for GROUP-scope club workouts created from Company run builder.
  athleteId                 String?
  /// Prod run_clubs.id when scope = GROUP.
  runClubId                 String?
  /// Company company_staff.id when staff created the group workout.
  createdByStaffId          String?
  scope                     WorkoutScope          @default(ATHLETE)
  /// Training plan this workout belongs to (null = standalone)
  planId                    String?
  /// Selected catalogue prescription when materialized from plan schedule
  catalogueWorkoutId        String?
  /// Scheduled calendar date for plan workouts
  date                      DateTime?
  /// Garmin field: planned total distance in meters (source of truth before segment expansion)
  estimatedDistanceInMeters Float?
  /// Weeks before race: first week = -(totalWeeks-1), race week = 0; null for standalone
  nOffset                   Int?
  /// 1-based week index within the plan; null for standalone
  weekNumber                Int?
  /// Assigned weekday name e.g. "Monday"; null for standalone
  dayAssigned               String?
  /// Intervals/Tempo: cycle position 0–3 fixed at plan generation (ordinal % 4); aligns with legacy schedule token `-iN`
  planCycleIndex            Int?
  /// Garmin Training API workout id after push-to-garmin (links activity → planned workout)
  garminWorkoutId           Int?
  /// Garmin Training API schedule id (calendar placement for this workout)
  garminScheduleId          Int?
  /// Matched activity after a run (promoted snapshot fields below)
  matchedActivityId         String?             @unique
  /// Athlete explicitly skipped this planned workout (distinct from past-unmatched "missed")
  skippedAt                 DateTime?
  skipReason                String?             @db.Text
  actualDistanceMeters      Float?
  actualAvgPaceSecPerMile   Int?
  actualAverageHeartRate    Int?
  actualDurationSeconds     Int?
  actualMaxHeartRate        Int?
  actualElevationGain       Float?
  actualCalories            Int?
  actualSteps               Int?
  /// Pace delta (sec/mi): targetPaceSecPerMile − actualAvgPaceSecPerMile. Positive = faster than prescribed.
  paceDeltaSecPerMile             Int?
  /// Main-segment target pace snapshot (sec/mi) used for paceDeltaSecPerMile.
  targetPaceSecPerMile            Int?
  /// Upper bound of main-segment pace target (sec/mi); lower/faster bound is targetPaceSecPerMile when both set.
  targetPaceSecPerMileHigh        Int?
  /// HR delta (bpm): target zone midpoint − actualAverageHeartRate. Positive = under zone.
  hrDeltaBpm                      Int?
  /// For quality workouts (Tempo/Intervals): implied 5K pace when paceDeltaSecPerMile >= 0.
  /// Formula: actualAvgPaceSecPerMile − catalogue rep offset.
  creditedFiveKPaceSecPerMile   Int?
  /// Successful Tempo: actual avg pace (sec/mi) used as threshold evidence when paceDelta >= 0.
  creditedThresholdPaceSecPerMile Int?
  /// Qualifying Easy/LongRun: average HR (bpm) used as aerobic-ceiling evidence when pace was not too fast vs target.
  creditedAerobicCeilingBpm       Int?
  evaluationEligibleFlag          Boolean             @default(false)
  /// ALIGNED | ALIGNMENT_FAILED after activity-to-segment parse
  segmentExecutionStatus          String?
  segmentExecutionLapCount        Int?
  segmentExecutionSegmentCount    Int?
  /// Frozen prescription segments at last materialize/send (segments table remains FK source for edits).
  segmentSnapshotJson               Json?
  /// Normalized copy of ingest summary payload (`athlete_activities.summaryData`).
  completedActivitySummaryJson      Json?
  /// Full detail payload when hydrated (`athlete_activities.detailData`).
  completedActivityDetailJson         Json?
  /// Computed readiness / delta summaries (product reads; optional).
  analysisJson                      Json?
  /// User-provided chips describing what shaped the run (before coach feedback).
  runContextTags                    String[]            @default([])
  /// Free-text note from athlete about the run context.
  runContextNote                    String?             @db.Text
  runContextUpdatedAt               DateTime?
  /// AI-generated pre-workout coach guidance (materialize + GET fallback; cached).
  prescriptionNarrative             String?
  /// Public share path slug for /mytrainingruns/[slug] (e.g. acole842719); set when athlete creates a join link
  slug                      String?             @unique
  /// Schedule-this-run UX: optional start time label (e.g. "6:30 AM")
  scheduledStartTimeLabel             String?
  scheduledMeetupLocation             String?
  scheduledRouteDescription           String?
  scheduledStravaRouteUrl             String?
  scheduledIsTrack                    Boolean             @default(false)
  /// Public join slug for /join/scheduled-run/[slug]
  scheduledShareSlug                  String?             @unique
  /// Planned workout reminder push — sent when Expo accepts the push
  appnotificationReminderSentAt       DateTime?
  /// Athlete acknowledged reminder in app inbox
  appnotificationReminderDeliveredAt  DateTime?
  appnotificationReminderLastError    String?
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
  Athlete                   Athlete?            @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  runClub                   run_clubs?          @relation(fields: [runClubId], references: [id], onDelete: SetNull)
  training_plans            training_plans?     @relation(fields: [planId], references: [id], onDelete: SetNull)
  workout_catalogue         workout_catalogue?  @relation(fields: [catalogueWorkoutId], references: [id], onDelete: SetNull)
  matched_activity          athlete_activities? @relation("WorkoutMatchedActivity", fields: [matchedActivityId], references: [id], onDelete: SetNull)
  segments                  workout_segments[]
  city_runs                 city_runs[]
  tri_workout_leg           tri_workout_leg?

  @@index([athleteId])
  @@index([runClubId])
  @@index([scope])
  @@index([workoutType])
  @@index([planId])
  @@index([planId, date])
  @@index([planId, weekNumber])
  @@index([planId, nOffset])
  @@index([athleteId, garminWorkoutId])
  @@index([catalogueWorkoutId])
}

model workout_segments {
  id               String            @id @default(cuid())
  workoutId        String
  stepOrder        Int               // Order in workout (1, 2, 3...)
  title            String            // e.g., "Warmup", "Main Set", "Cooldown", "Interval"
  // Duration
  durationType     String            // "DISTANCE" or "TIME"
  durationValue    Float             // Miles (if DISTANCE) or minutes (if TIME)
  // Targets (generic - matches Garmin structure)
  targets          Json?             // Array of target objects: [{ type: "PACE", valueLow: 480, valueHigh: 500 }, { type: "HEART_RATE", valueLow: 160, valueHigh: 180 }]
  /// 1 = legacy PACE values (inflated); 2 = true sec/km per Garmin — see lib/workout-generator/pace-calculator.ts
  paceTargetEncodingVersion Int         @default(2)
  // Repeat capability
  repeatCount      Int?              // Repeat this segment N times (for intervals)
  /// Between-rep recovery nested inside Garmin repeat when set (miles or minutes; NONE clears).
  recoveryDurationType  String?      // "DISTANCE" | "TIME" | "NONE"
  recoveryDurationValue Float?        // Miles if DISTANCE, minutes if TIME
  /// Lap-matched actuals (prescribed targets JSON is never overwritten)
  actualPaceSecPerMile   Int?
  actualDistanceMiles    Float?
  actualDurationSeconds  Int?
  // Metadata
  notes            String?           // User notes for this segment
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  workout          workouts          @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  segment_laps     workout_segment_laps[]

  @@index([workoutId])
  @@index([workoutId, stepOrder])
}

/// One row per Garmin lap mapped to a prescribed workout segment after activity parse.
model workout_segment_laps {
  id                  String              @id @default(cuid())
  activityId          String
  segmentId           String
  /// 0-based index in the original Garmin Laps[] array
  lapIndex            Int
  startTimeInSeconds  Int
  endTimeInSeconds    Int
  avgPaceSecPerMile   Int?
  avgHeartRate        Int?
  distanceMiles       Float?
  durationSeconds     Int?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  activity            athlete_activities  @relation(fields: [activityId], references: [id], onDelete: Cascade)
  segment             workout_segments    @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  @@unique([activityId, lapIndex])
  @@unique([segmentId, lapIndex])
  @@index([segmentId])
  @@index([activityId])
}

/// Sport for a leg within a tri / multi-sport session (ordering is on tri_workout_leg.legOrder).
enum TriSport {
  Swim
  Bike
  Run
}

/// Standalone or tri-linked cycling workout — TIME + power targets (watts).
model bike_workout {
  id                       String              @id @default(cuid())
  athleteId                String
  title                    String
  description              String?
  date                     DateTime?
  /// Athlete FTP at creation time (optional denormalized snapshot).
  ftpWattsSnapshot         Int?
  estimatedDurationSeconds Int?
  garminWorkoutId          Int?
  garminScheduleId         Int?
  matchedActivityId        String?             @unique
  actualDurationSeconds    Int?
  actualDistanceMeters     Float?
  actualAvgPowerWatts      Int?
  actualAverageHeartRate   Int?
  actualMaxHeartRate       Int?
  actualElevationGain      Float?
  actualCalories           Int?
  /// actual avg power minus planned step target midpoint (watts); positive = rode above target.
  powerDeltaWatts          Int?
  notes                    String?
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  Athlete                  Athlete             @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  steps                    bike_workout_step[]
  tri_workout_leg          tri_workout_leg?
  matched_activity         athlete_activities? @relation("BikeWorkoutMatchedActivity", fields: [matchedActivityId], references: [id], onDelete: SetNull)

  @@index([athleteId])
  @@index([athleteId, date])
}

model bike_workout_step {
  id              String       @id @default(cuid())
  bikeWorkoutId   String
  stepOrder       Int
  title           String
  intensity       String
  repeatCount     Int?
  durationType    String
  durationSeconds Int?
  powerWattsLow   Int?
  powerWattsHigh  Int?
  heartRateLow    Int?
  heartRateHigh   Int?
  cadenceLow      Int?
  cadenceHigh     Int?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  bikeWorkout     bike_workout @relation(fields: [bikeWorkoutId], references: [id], onDelete: Cascade)

  @@index([bikeWorkoutId])
  @@index([bikeWorkoutId, stepOrder])
}

/// Standalone or tri-linked swim workout — distance/time + pace per 100m.
model swim_workout {
  id               String              @id @default(cuid())
  athleteId        String
  title            String
  description      String?
  date             DateTime?
  poolLengthMeters Int?
  cssSecPer100m    Int?
  garminWorkoutId  Int?
  garminScheduleId Int?
  notes            String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  Athlete          Athlete             @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  steps            swim_workout_step[]
  tri_workout_leg  tri_workout_leg?

  @@index([athleteId])
  @@index([athleteId, date])
}

model swim_workout_step {
  id                 String       @id @default(cuid())
  swimWorkoutId      String
  stepOrder          Int
  title              String
  intensity          String
  repeatCount        Int?
  durationType       String
  durationMeters     Int?
  durationSeconds    Int?
  paceSecPer100mLow  Int?
  paceSecPer100mHigh Int?
  strokeType         String?
  equipment          String?
  heartRateLow       Int?
  heartRateHigh      Int?
  notes              String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  swimWorkout        swim_workout @relation(fields: [swimWorkoutId], references: [id], onDelete: Cascade)

  @@index([swimWorkoutId])
  @@index([swimWorkoutId, stepOrder])
}

/// Multi-sport session shell — links ordered sport-specific workouts (brick, tri sim, etc.).
model tri_workout {
  id          String            @id @default(cuid())
  athleteId   String
  title       String
  description String?
  date        DateTime?
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  Athlete     Athlete           @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  legs        tri_workout_leg[]

  @@index([athleteId])
  @@index([athleteId, date])
}

model tri_workout_leg {
  id             String      @id @default(cuid())
  triWorkoutId   String
  legOrder       Int
  sport          TriSport
  title          String?
  bikeWorkoutId  String?     @unique
  swimWorkoutId  String?     @unique
  runWorkoutId   String?     @unique
  triWorkout     tri_workout @relation(fields: [triWorkoutId], references: [id], onDelete: Cascade)
  bikeWorkout    bike_workout? @relation(fields: [bikeWorkoutId], references: [id])
  swimWorkout    swim_workout? @relation(fields: [swimWorkoutId], references: [id])
  runWorkout     workouts?     @relation(fields: [runWorkoutId], references: [id])

  @@index([triWorkoutId])
  @@index([triWorkoutId, legOrder])
}

