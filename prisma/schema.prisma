generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Unpooled Neon host (no "-pooler"). Used for prisma migrate; runtime uses DATABASE_URL.
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum AthleteRole {
  USER          // Default - regular user
  CLUB_LEADER   // Club leader - can manage their RunClub's CityRuns
  AMBASSADOR    // Ambassador - can manage their RunClub's CityRuns (future)
}

/// At most one ACTIVE training plan per athlete (enforced in application code).
enum TrainingPlanLifecycle {
  ACTIVE
  ARCHIVED
  /// Plan replaced or abandoned before natural completion — not a completed lifecycle.
  OLD_PLAN_UNUSED
}

enum CoachReviewStatus {
  DRAFT
  PUBLISHED
}

model Athlete {
  id                      String                   @id @default(uuid())
  firebaseId              String                   @unique
  email                   String?
  companyId               String
  firstName               String?
  lastName                String?
  gofastHandle            String?                  @unique
  photoURL                String?
  /// GoFast Page hero — finish line / action shot (public). URL string.
  myBestRunPhotoURL       String?
  phoneNumber             String?
  birthday                DateTime?
  gender                  String?
  city                    String?
  state                   String?
  primarySport            String?
  bio                     String?
  instagram               String?
  /// Opt-in: GoFast Page acts as a lightweight community (membership + chatter).
  isGoFastContainer       Boolean                  @default(false)
  garmin_user_id          String?                  @unique
  garmin_access_token      String?
  garmin_refresh_token     String?
  garmin_expires_in        Int?
  garmin_scope             String?
  garmin_connected_at      DateTime?
  garmin_last_sync_at      DateTime?
  garmin_is_connected      Boolean                  @default(false)
  garmin_disconnected_at   DateTime?
  garmin_permissions       Json?
  garmin_user_profile      Json?
  garmin_user_sleep        Json?
  garmin_user_daily        Json?
  garmin_user_preferences  Json?
  strava_id               Int?                     @unique
  strava_access_token     String?
  strava_refresh_token    String?
  strava_expires_at       Int?
  fiveKPace               String?
  /// Tempo-derived sustained pace (formatted like fiveKPace); updated from successful Tempo completions only.
  thresholdPace           String?
  /// Estimated upper heart rate (bpm) for truly easy aerobic work; updated conservatively from Easy/LongRun completions.
  aerobicCeilingBpm       Int?
  /// Best completed long run — adjusts GoFast race projection k-coefficient.
  longRunCapabilityMiles          Float?
  longRunCapabilityPaceSecPerMile   Int?
  longRunCapabilityDate           DateTime?
  /// Functional threshold power (watts) — bike workout intensity anchor.
  ftpWatts                Int?
  weeklyMileage           Int?
  /// Profile hydration snapshot: copied from active goal for quick reads.
  primaryGoalNameSnapshot            String?
  primaryGoalTimeSnapshot            String?
  primaryGoalTargetByDateSnapshot    DateTime?
  primaryGoalRaceNameSnapshot        String?
  /// Profile hydration snapshot: copied from primary race for quick reads.
  primaryRaceRegistryIdSnapshot      String?
  primaryRaceSlugSnapshot            String?
  primaryRaceNameSnapshot            String?
  primaryRaceDateSnapshot            DateTime?
  primaryRaceDistanceLabelSnapshot   String?
  primaryRaceCitySnapshot            String?
  primaryRaceStateSnapshot           String?
  role                    AthleteRole               @default(USER)
  runClubId               String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  /// Last app bootstrap (GET /api/athlete/me or POST /api/athlete/create)
  lastSeenAt              DateTime?
  /// Rolling 90d avg weekly miles from athlete_activities — populated by cron, not computed on read.
  avgWeeklyMilesSnapshot  Float?
  /// When avgWeeklyMilesSnapshot was last written by the mileage cron.
  mileageSnapshotUpdatedAt DateTime?
  go_fast_companies       go_fast_companies        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  runClub                 run_clubs?               @relation(fields: [runClubId], references: [id], onDelete: SetNull)
  ambassador_credits      ambassador_credits[]
  ambassador_payouts      ambassador_payouts[]
  athlete_activities      athlete_activities[]
  athlete_health_records  athlete_health_records[]
  run_crew_announcements  run_crew_announcements[]
  run_crew_event_rsvps    run_crew_event_rsvps[]
  run_crew_events         run_crew_events[]
  run_crew_memberships    run_crew_memberships[]
  run_crew_messages       run_crew_messages[]
  run_club_memberships    run_club_memberships[]
  run_club_leader_claims    run_club_leader_claims[]
  run_club_announcements  run_club_announcements[]
  run_club_events         run_club_events[]
  run_club_event_rsvps    run_club_event_rsvps[]
  city_run_rsvps          city_run_rsvps[]
  city_run_messages       city_run_messages[]
  city_run_checkins       city_run_checkins[]
  city_run_activity_links city_run_activity_links[]
  city_runs               city_runs[]
  routes                  routes[]
  training_plans          training_plans[]
  workouts                workouts[]
  bike_workouts           bike_workout[]
  swim_workouts           swim_workout[]
  tri_workouts            tri_workout[]
  athlete_goals           AthleteGoal[]
  athlete_race_signups    athlete_race_signups[]
  athlete_race_results    athlete_race_results[]
  race_memberships        race_memberships[]
  training_cohort_memberships training_cohort_memberships[]
  training_cohort_messages training_cohort_messages[]
  race_messages           race_messages[]
  race_announcements      race_announcements[]
  race_events_organized   race_events[]            @relation("RaceEventOrganizer")
  race_event_rsvps        race_event_rsvps[]
  training_preferences    TrainingPreferences?
  run_journal_entries     run_journal_entries[]
  pace_adjustment_logs    pace_adjustment_log[]
  hosted_container_memberships  gofast_container_memberships[] @relation("ContainerHost")
  member_container_memberships   gofast_container_memberships[] @relation("ContainerMember")
  container_messages_as_host     gofast_container_messages[]    @relation("ContainerMessages")
  container_messages_as_author   gofast_container_messages[]    @relation("ContainerMessageAuthor")
  athlete_appnotification_devices     athlete_appnotification_devices[]
}

/// Human coach — first-class entity (Firebase auth), parallel to Athlete.
model Coach {
  id         String   @id @default(cuid())
  firebaseId String   @unique
  email      String?
  companyId  String
  firstName  String?
  lastName   String?
  photoURL   String?
  bio        String?
  specialty  String?
  city       String?
  state      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  go_fast_companies go_fast_companies @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("coaches")
}

/// Weekly batch analysis result OR per-workout match notification.
/// notificationType: 'PACE_UPDATE' (weekly credit) | 'WORKOUT_MATCH' (per-workout feedback).
/// Pace fields are nullable — only set for PACE_UPDATE rows.
model pace_adjustment_log {
  id                           String         @id @default(cuid())
  athleteId                    String
  planId                       String?
  weekNumber                   Int?
  workoutId                    String?
  notificationType             String?        @default("PACE_UPDATE")
  previousPaceSecPerMile       Int?
  newPaceSecPerMile            Int?
  adjustmentSecPerMile         Int?
  qualityWorkoutsCount         Int            @default(0)
  qualityAvgDeltaSecPerMile    Int?
  longRunCompleted             Boolean        @default(false)
  longRunCompletionRatio       Float?
  weeklyMileageCompletionPct   Float?
  summaryMessage               String?
  seenAt                       DateTime?
  createdAt                    DateTime       @default(now())
  Athlete                      Athlete        @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  training_plans               training_plans? @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@index([athleteId, seenAt])
  @@index([planId, weekNumber])
}

model gofast_container_memberships {
  id                 String   @id @default(cuid())
  containerAthleteId String
  memberAthleteId    String
  role               String   @default("member")
  joinedAt           DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  containerAthlete   Athlete  @relation("ContainerHost", fields: [containerAthleteId], references: [id], onDelete: Cascade)
  memberAthlete      Athlete  @relation("ContainerMember", fields: [memberAthleteId], references: [id], onDelete: Cascade)

  @@unique([containerAthleteId, memberAthleteId])
  @@index([containerAthleteId])
}

model gofast_container_messages {
  id                 String   @id @default(cuid())
  containerAthleteId String
  authorAthleteId    String
  body               String
  createdAt          DateTime @default(now())
  containerAthlete   Athlete  @relation("ContainerMessages", fields: [containerAthleteId], references: [id], onDelete: Cascade)
  authorAthlete      Athlete  @relation("ContainerMessageAuthor", fields: [authorAthleteId], references: [id], onDelete: Cascade)

  @@index([containerAthleteId, createdAt])
}

model ambassador_credits {
  id              String           @id @default(cuid())
  athleteId       String
  cityRunRsvpId   String           @unique         // One credit per RSVP (RSVP going + photo)
  amountCents     Int              @default(1000)  // $10 per qualified run
  createdAt       DateTime         @default(now())
  Athlete         Athlete          @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  city_run_rsvps  city_run_rsvps   @relation(fields: [cityRunRsvpId], references: [id], onDelete: Cascade)

  @@index([athleteId])
  @@index([createdAt])
}

model ambassador_payouts {
  id               String    @id @default(cuid())
  athleteId        String
  processedAt      DateTime  // When Company paid (period end for credits)
  amountCents      Int
  companyPayoutId  String?   // FK/id from GoFast Company payouts table (if synced)
  createdAt        DateTime  @default(now())
  Athlete          Athlete   @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@index([athleteId])
  @@index([processedAt])
}

model athlete_activities {
  id               String            @id
  athleteId        String
  sourceActivityId String            @unique
  source           String            @default("garmin")
  /// RECEIVED | MATCHED | UNMATCHED | INELIGIBLE — ingest → promote lifecycle
  ingestionStatus  String            @default("RECEIVED")
  activityType     String?
  activityName     String?
  startTime        DateTime?
  duration         Int?
  distance         Float?
  calories         Int?
  averageSpeed     Float?
  averageHeartRate Int?
  maxHeartRate     Int?
  elevationGain    Float?
  averagePower     Int?
  steps            Int?
  startLatitude    Float?
  startLongitude   Float?
  endLatitude      Float?
  endLongitude     Float?
  summaryPolyline  String?
  summaryData      Json?
  detailData       Json?
  hydratedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime
  Athlete          Athlete           @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  matched_workout  workouts?         @relation("WorkoutMatchedActivity")
  matched_bike_workout bike_workout? @relation("BikeWorkoutMatchedActivity")
  city_run_activity_links city_run_activity_links[]
  athlete_race_result athlete_race_results?
  workout_segment_laps workout_segment_laps[]

  @@index([athleteId, ingestionStatus])
}

/// Garmin Health API summaries (dailies, sleeps) — off Athlete row to avoid profile bloat.
model athlete_health_records {
  id              String    @id @default(cuid())
  athleteId       String
  source          String    @default("garmin")
  /// "daily" | "sleep" — matches Garmin Health webhook keys (dailies, sleeps)
  healthType      String
  sourceSummaryId String?
  calendarDate    DateTime?
  summaryData     Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  Athlete         Athlete   @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@unique([source, healthType, sourceSummaryId])
  @@index([athleteId, healthType, calendarDate])
}

/// Athlete linked a synced activity (or attendance-only) to a city run for credit / history.
model city_run_activity_links {
  id             String   @id @default(cuid())
  cityRunId      String
  athleteId      String
  activityId     String?
  linkedManually Boolean  @default(true)
  createdAt      DateTime @default(now())

  city_runs          city_runs           @relation(fields: [cityRunId], references: [id], onDelete: Cascade)
  Athlete            Athlete             @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  athlete_activities athlete_activities? @relation(fields: [activityId], references: [id], onDelete: SetNull)

  @@unique([cityRunId, athleteId])
  @@index([athleteId])
  @@index([activityId])
}

model cities {
  id            String          @id
  slug          String          @unique
  name          String
  state         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  run_clubs     run_clubs[]
  run_series    run_series[]
  city_runs     city_runs[]
  routes        routes[]
  run_locations run_locations[]

  @@index([name])
  @@index([slug])
}

model go_fast_companies {
  id        String    @id
  name      String?
  slug      String?   @unique
  address   String?
  city      String?
  state     String?
  zip       String?
  domain    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime
  Athlete   Athlete[]
  Coach     Coach[]
}

model join_codes {
  id        String    @id
  code      String    @unique
  runCrewId String
  createdAt DateTime  @default(now())
  expiresAt DateTime?
  isActive  Boolean   @default(true)
  run_crews run_crews @relation(fields: [runCrewId], references: [id], onDelete: Cascade)
}

// TODO(race-prep): Athlete-facing course preview / training-plan tie-in may need a
// race_registry_courses junction or companyRaceId reference to structured course data.
// Company remains canonical for course geometry; do not duplicate until feature is scoped.

model race_registry {
  id                      String                    @id
  name                    String
  city                    String?
  state                   String?
  country                 String?                   @default("USA")
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime
  charityName             String?
  charityUrl              String?
  courseMapUrl            String?
  /// Public content site /course/[slug] — from Company race_courses.slug (prodpush).
  courseSlug              String?
  description             String?
  /// Short tagline / card summary (from Company sync).
  summaryPhrase           String?
  /// Canonical race distance in meters (aligned with GoFastCompany race_registrations).
  distanceMeters          Int?
  isActive                Boolean                   @default(true)
  isCancelled             Boolean                   @default(false)
  isVirtual               Boolean                   @default(false)
  officialWebsiteUrl      String?
  raceDate                DateTime
  registrationCloseDate   DateTime?
  /// Capacity closed before deadline (e.g. sold out); hides external registration CTA.
  registrationSoldOut     Boolean                   @default(false)
  /// Last calendar day for official bib transfers (separate from registration close).
  transferDeadline        DateTime?
  registrationFee         Float?
  registrationOpenDate    DateTime?
  registrationOpenNow     Boolean                   @default(false)
  registrationUrl         String?
  resultsUrl              String?
  slug                    String?                   @unique
  /// Wall-clock label from GoFastCompany (e.g. "10:00 AM"); not a timezone-aware instant.
  startTime               String?
  tags                    String[]                  @default([])
  /// When set, matches GoFastCompany races.id (multiple registry rows per race = multiple distances).
  companyRaceId           String?
  /// GoFastCompany race_registrations.id — stable upsert key per distance.
  companyRegistrationId   String?                   @unique
  /// Companion distances (5K, 10 Mile…) point to the primary/marathon row.
  parentRaceId            String?
  parentRace              race_registry?            @relation("RaceFamily", fields: [parentRaceId], references: [id])
  childRaces              race_registry[]           @relation("RaceFamily")
  /// External image URL for browse cards (editorial asset or CDN).
  logoUrl                 String?
  /// Distance label from registration or pipe-joined snapshot from company sync.
  distanceLabel           String?
  /// Racer-facing snapshot from Company; set by sync only.
  packetPickupLocation     String?
  packetPickupDate         DateTime?
  packetPickupTime         String?
  packetPickupDescription  String?
  spectatorInfo           String?
  logisticsInfo           String?
  gearDropInstructions    String?
  run_crew_specific_races  run_crew_specific_races[]
  run_crews                run_crews[]
  training_plans           training_plans[]
  training_cohorts         training_cohorts[]
  training_cohort_memberships training_cohort_memberships[]
  athlete_goals            AthleteGoal[]
  athlete_race_signups     athlete_race_signups[]
  athlete_race_results     athlete_race_results[]
  race_memberships         race_memberships[]
  race_messages            race_messages[]
  race_announcements       race_announcements[]
  race_events              race_events[]
  city_runs_tagged         city_runs[]               @relation("CityRunRaceRegistry")
  course_segments          race_registry_course_segments[]

  @@index([city, state])
  @@index([isActive])
  @@index([raceDate])
  @@index([slug])
  @@index([tags])
  @@index([companyRaceId])
  @@index([parentRaceId])
  @@index([companyRegistrationId])
}

/// Course segments mirrored from GoFastCompany race_course_segments (prodpush).
model race_registry_course_segments {
  id               String        @id @default(cuid())
  raceRegistryId   String
  /// GoFastCompany race_course_segments.id
  companySegmentId String        @unique
  order            Int
  name             String
  mileMarker       String?
  description      String?
  runTip           String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  raceRegistry     race_registry @relation(fields: [raceRegistryId], references: [id], onDelete: Cascade)

  @@index([raceRegistryId])
}

/// Universal athlete goal (1:N). Goal paces derived and stored on create/update.
model AthleteGoal {
  id               String         @id @default(cuid())
  athleteId        String
  name             String?
  description      String?        @db.Text
  distance         String
  goalTime         String?
  goalRacePace     Int?
  goalPace5K       Int?
  targetByDate     DateTime
  raceRegistryId   String?
  status           String         @default("ACTIVE")
  whyGoal          String?        @db.Text
  successLooksLike String?        @db.Text
  completionFeeling String?     @db.Text
  motivationIcon   String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  Athlete          Athlete        @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  race_registry    race_registry? @relation(fields: [raceRegistryId], references: [id], onDelete: SetNull)
  training_plans   training_plans[]
  athlete_race_signups athlete_race_signups[]
  athlete_race_results athlete_race_results[]

  @@index([athleteId])
  @@index([athleteId, status])
  @@index([raceRegistryId])
  @@map("athlete_goals")
}

/// Self-declared "I'm doing this race" — independent of goals/plans.
model athlete_race_signups {
  id              String   @id @default(cuid())
  athleteId       String
  raceRegistryId  String
  selfDeclaredAt  DateTime @default(now())
  goalId          String?
  notifyEnabled   Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  Athlete        Athlete        @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  race_registry  race_registry  @relation(fields: [raceRegistryId], references: [id], onDelete: Cascade)
  athlete_goal   AthleteGoal?   @relation(fields: [goalId], references: [id], onDelete: SetNull)
  athlete_race_result athlete_race_results?

  @@unique([athleteId, raceRegistryId])
  @@index([athleteId])
  @@index([raceRegistryId])
  @@map("athlete_race_signups")
}

/// Persisted finish data for a race (manual or linked Garmin activity).
model athlete_race_results {
  id                     String   @id @default(cuid())
  athleteId              String
  raceRegistryId         String
  signupId               String?  @unique
  goalId                 String?  @unique
  /// Primary display time — chip or net when that is the official "finish" (string "H:MM:SS" or "MM:SS").
  officialFinishTime     String?
  chipTime               String?
  gunTime                String?
  /// Net finish in seconds (for goal / PR analysis).
  finishTimeSeconds      Int?
  /// Goal time in seconds (snapshot from AthleteGoal.goalTime at log time).
  goalTimeSeconds        Int?
  /// finishTimeSeconds - goalTimeSeconds; negative = beat goal (faster).
  goalTimeDeltaSeconds   Int?
  goalAchieved           Boolean  @default(false)
  prAchieved             Boolean  @default(false)
  /// Prior best for same distance (seconds) when PR was set.
  previousPrSeconds      Int?
  /// When the race was run (defaults from registry or goal).
  raceDate               DateTime?
  /// Snapshot: Marathon, 5K, etc.
  distanceLabel          String?
  reflection             String?  @db.Text
  /// Public URLs (e.g. Vercel Blob) for race-day photos; no enforced max count.
  racePhotoUrls          String[] @default([])
  howFeltRating          Int?
  actualDistanceMeters     Float?
  actualAvgPaceSecPerMile  Int?
  overallPlace           Int?
  ageGroupPlace          Int?
  divisionPlace          Int?
  source                 String   @default("manual")
  /// Optional link to a synced `athlete_activities` row (e.g. Garmin).
  garminActivityId       String?  @unique
  notes                  String?  @db.Text
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  Athlete              Athlete            @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  race_registry        race_registry      @relation(fields: [raceRegistryId], references: [id], onDelete: Cascade)
  athlete_race_signup  athlete_race_signups? @relation(fields: [signupId], references: [id], onDelete: SetNull)
  athlete_goal         AthleteGoal?        @relation(fields: [goalId], references: [id], onDelete: SetNull)
  athlete_activity     athlete_activities?  @relation(fields: [garminActivityId], references: [id], onDelete: SetNull)

  @@unique([athleteId, raceRegistryId])
  @@index([athleteId])
  @@index([raceRegistryId])
  @@index([goalId])
  @@map("athlete_race_results")
}

/// Join a race registry → access race chatter and container features (mirrors run_crew_memberships).
model race_memberships {
  id        String         @id @default(cuid())
  raceId    String
  athleteId String
  role      RaceMemberRole @default(MEMBER)
  joinedAt  DateTime       @default(now())

  race_registry race_registry @relation(fields: [raceId], references: [id], onDelete: Cascade)
  Athlete       Athlete       @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@unique([raceId, athleteId])
  @@index([raceId])
  @@index([athleteId])
  @@map("race_memberships")
}

/// Race-scoped chatter (mirrors run_crew_messages).
model race_messages {
  id        String   @id @default(cuid())
  raceId    String
  athleteId String
  content   String
  topic     String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  race_registry race_registry @relation(fields: [raceId], references: [id], onDelete: Cascade)
  Athlete       Athlete       @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@index([raceId])
  @@index([athleteId])
  @@map("race_messages")
}

model race_announcements {
  id               String    @id @default(cuid())
  raceId           String
  authorId         String?
  staffGeneratedId String?
  title            String
  content          String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  archivedAt       DateTime?

  race_registry race_registry @relation(fields: [raceId], references: [id], onDelete: Cascade)
  Athlete       Athlete?      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([raceId])
  @@index([staffGeneratedId])
  @@map("race_announcements")
}

/// Race-day / training meetups tied to a race (mirrors run_crew_events).
model race_events {
  id                String   @id @default(cuid())
  raceId            String
  organizerId       String
  title             String
  date              DateTime
  time              String
  venue             String
  address           String?
  description       String?
  additionalDetails String?
  cost              Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  race_registry     race_registry      @relation(fields: [raceId], references: [id], onDelete: Cascade)
  organizer         Athlete            @relation("RaceEventOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  race_event_rsvps  race_event_rsvps[]

  @@index([raceId])
  @@index([date])
  @@map("race_events")
}

model race_event_rsvps {
  id        String   @id @default(cuid())
  eventId   String
  athleteId String
  status    String
  createdAt DateTime @default(now())

  race_events race_events @relation(fields: [eventId], references: [id], onDelete: Cascade)
  Athlete     Athlete     @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@unique([eventId, athleteId])
  @@map("race_event_rsvps")
}

/// Free-form training journal entries (Runner OS).
model run_journal_entries {
  id        String   @id @default(cuid())
  athleteId String
  date      DateTime @default(now())
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Athlete   Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@index([athleteId])
  @@index([athleteId, date])
  @@map("run_journal_entries")
}

/// Athlete-level schedule / volume preferences (1:1), independent of any training plan.
model TrainingPreferences {
  id                   String   @id @default(cuid())
  athleteId            String   @unique
  preferredDays        Int[]
  weeklyMileageTarget  Int?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  Athlete              Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@map("training_preferences")
}

/// Public brand row — prodpush from Company acq_brands; slug is the bridge key.
model brands {
  id              String    @id @default(uuid())
  slug            String    @unique
  name            String
  brandType       BrandType @default(OTHER)
  description     String?
  websiteUrl      String?
  instagramHandle String?
  logoUrl         String?
  syncedAt        DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  run_clubs       run_clubs[]

  @@map("brands")
}

model run_clubs {
  id        String   @id @default(uuid())
  slug      String   @unique
  name      String
  brandId   String?
  brands    brands?  @relation(fields: [brandId], references: [id], onDelete: SetNull)
  logoUrl      String?
  city         String?
  /// Canonical city slug (dc, arlington) — synced from Company prodpush; computed from city when set.
  citySlug     String?
  /// FK to cities — server-derived on save for city guide hydration.
  cityId       String?
  cities       cities?  @relation(fields: [cityId], references: [id], onDelete: SetNull)
  /// HQ / central office from Google Places (affiliation canon).
  hqPlaceId          String?
  hqFormattedAddress String?
  hqStreet           String?
  hqZip              String?
  hqLat              Float?
  hqLng              Float?
  /// Club runs in multiple municipalities; series rows need per-row city from Places.
  isMultiSite  Boolean  @default(false)
  state        String?
  neighborhood String?
  description String?              // General club description (for downstream display)
  allRunsDescription String?      // Overall description for this club's run series (not per individual run) — drives run_series.description
  websiteUrl String?
  runUrl    String?              // "Runs" page URL — single source of truth for where run/series info came from (seed/hydrate for data entry)
  instagramUrl String?
  stravaUrl String?              // Club Strava — source for AI; data entry can look up
  syncedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  runs                  city_runs[]
  groupWorkouts         workouts[]
  clubLeaders           Athlete[]                  // Reverse relation for Athlete.runClubId
  runSeries             run_series[]               // Recurring series this club owns (run_series.runClubId → run_clubs)
  run_club_memberships  run_club_memberships[]
  run_club_leader_claims  run_club_leader_claims[]
  run_club_announcements run_club_announcements[]
  run_club_events       run_club_events[]

  @@index([brandId])
  @@index([city])
  @@index([cityId])
  @@index([citySlug])
  @@index([slug])
}

/// Club-level membership — join/follow the run club (separate from per-run RSVPs).
model run_club_memberships {
  id        String    @id @default(cuid())
  runClubId String
  athleteId String
  role      String    @default("member") // member | admin | owner
  status    String    @default("active") // active | left | blocked
  joinedAt  DateTime  @default(now())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  run_clubs run_clubs @relation(fields: [runClubId], references: [id], onDelete: Cascade)
  Athlete   Athlete   @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@unique([runClubId, athleteId])
  @@index([runClubId])
  @@index([athleteId])
  @@map("run_club_memberships")
}

/// Pre-seeded club-owner slots from Company — athlete claims by verified email match.
model run_club_leader_claims {
  id                   String    @id @default(cuid())
  runClubId            String
  email                String
  membershipRole       String    @default("admin") // admin | owner
  status               String    @default("unclaimed") // unclaimed | claimed | revoked
  acqClubLeaderId      String?
  acqRunClubId         String?
  managerAssignmentId  String?
  inviteTokenHash      String?   @unique
  inviteExpiresAt      DateTime?
  lastInviteSentAt     DateTime?
  claimedByAthleteId   String?
  claimedAt            DateTime?
  source               String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  run_clubs            run_clubs @relation(fields: [runClubId], references: [id], onDelete: Cascade)
  Athlete              Athlete?  @relation(fields: [claimedByAthleteId], references: [id], onDelete: SetNull)

  @@unique([runClubId, email])
  @@index([email, status])
  @@index([runClubId])
  @@map("run_club_leader_claims")
}

/// Club broadcast content — announcements visible to members (and optionally public).
model run_club_announcements {
  id          String    @id @default(cuid())
  runClubId   String
  authorId    String
  title       String?
  body        String
  visibility  String    @default("members") // public | members
  publishedAt DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  run_clubs   run_clubs @relation(fields: [runClubId], references: [id], onDelete: Cascade)
  Athlete     Athlete   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([runClubId, publishedAt])
  @@map("run_club_announcements")
}

/// Non-run club events: socials, clinics, sponsor activations, etc.
model run_club_events {
  id                   String                 @id @default(cuid())
  runClubId            String
  creatorId            String
  title                String
  description          String?
  eventType            String                 @default("social") // social | clinic | sponsor | volunteer | race | other
  startsAt             DateTime
  endsAt               DateTime?
  location             String?
  visibility           String                 @default("public") // public | members
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  run_clubs            run_clubs              @relation(fields: [runClubId], references: [id], onDelete: Cascade)
  Athlete              Athlete                @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  run_club_event_rsvps run_club_event_rsvps[]

  @@index([runClubId, startsAt])
  @@map("run_club_events")
}

/// RSVPs for club events (separate from city_run_rsvps).
model run_club_event_rsvps {
  id              String          @id @default(cuid())
  eventId         String
  athleteId       String
  status          String          @default("going") // going | maybe | not-going
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  run_club_events run_club_events @relation(fields: [eventId], references: [id], onDelete: Cascade)
  Athlete         Athlete         @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@unique([eventId, athleteId])
  @@index([athleteId])
  @@map("run_club_event_rsvps")
}

model run_crew_announcements {
  id         String    @id
  runCrewId  String
  authorId   String
  title      String
  content    String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime
  archivedAt DateTime? @db.Timestamp(6)
  Athlete    Athlete   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  run_crews  run_crews @relation(fields: [runCrewId], references: [id], onDelete: Cascade)
}

model run_crew_event_rsvps {
  id              String          @id
  eventId         String
  athleteId       String
  status          String
  createdAt       DateTime        @default(now())
  Athlete         Athlete         @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  run_crew_events run_crew_events @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, athleteId])
}

model run_crew_events {
  id                   String                 @id
  runCrewId            String
  organizerId          String
  title                String
  date                 DateTime
  time                 String
  address              String?
  description          String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  additionalDetails    String?
  cost                 Int?
  venue                String
  run_crew_event_rsvps run_crew_event_rsvps[]
  Athlete              Athlete                @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  run_crews            run_crews              @relation(fields: [runCrewId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([runCrewId])
}

model run_crew_memberships {
  id        String      @id
  runCrewId String
  athleteId String
  joinedAt  DateTime    @default(now())
  createdAt DateTime    @default(now())
  updatedAt DateTime
  role      RunCrewRole @default(member)
  Athlete   Athlete     @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  run_crews run_crews   @relation(fields: [runCrewId], references: [id], onDelete: Cascade)

  @@unique([runCrewId, athleteId])
  @@index([runCrewId, role])
}

model run_crew_messages {
  id        String    @id
  runCrewId String
  athleteId String
  content   String
  createdAt DateTime  @default(now())
  topic     String    @default("general")
  updatedAt DateTime
  Athlete   Athlete   @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  run_crews run_crews @relation(fields: [runCrewId], references: [id], onDelete: Cascade)
}

model city_run_checkins {
  id          String    @id
  runId       String
  athleteId   String
  checkedInAt DateTime  @default(now())
  runPhotoUrl String?   // athlete's photo from this run
  runShouts   String?   // post-run shout-out / comment
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  Athlete     Athlete   @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  city_runs   city_runs @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, athleteId])
  @@index([runId])
  @@index([athleteId])
  @@map("city_run_checkins")
}

model city_run_messages {
  id        String     @id
  runId     String
  athleteId String
  content   String
  topic     String     @default("general")
  createdAt DateTime   @default(now())
  updatedAt DateTime
  Athlete   Athlete    @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  city_runs city_runs  @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([athleteId])
  @@index([topic])
  @@map("city_run_messages")
}

model city_run_rsvps {
  id              String        @id
  runId           String
  athleteId       String
  status          String        // "going", "not-going", "maybe"
  occurrenceDate  DateTime?     // null = standalone run; set = recurring (the specific occurrence date)
  checkedInAt     DateTime?     // Timestamp when checked in (null = not checked in)
  rsvpPhotoUrls   Json?         // Photos attendee posted for this run (ambassador credit when going + ≥1 photo)
  createdAt       DateTime      @default(now())
  Athlete         Athlete       @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  city_runs       city_runs     @relation(fields: [runId], references: [id], onDelete: Cascade)
  ambassador_credits ambassador_credits?

  @@unique([runId, athleteId])
  @@index([checkedInAt])
  @@index([occurrenceDate])
}

/// Reusable running route (Strava reference + media). Start/end for events stay on city_runs.
model routes {
  id                 String   @id @default(cuid())
  name               String
  stravaUrl          String?
  distanceMiles      Float?
  stravaMapUrl       String?
  mapImageUrl        String?
  routePhotos        Json?
  routeNeighborhood  String?
  runType            String?
  /// City slug for lookup (e.g. dc); city_runs.citySlug remains source of truth for the event.
  citySlug           String?
  cityId             String?
  cities             cities?  @relation(fields: [cityId], references: [id], onDelete: SetNull)
  createdByAthleteId String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  createdBy          Athlete  @relation(fields: [createdByAthleteId], references: [id], onDelete: Cascade)
  city_runs          city_runs[]

  @@index([citySlug])
  @@index([cityId])
  @@index([name])
  @@map("routes")
}

model city_runs {
  id                  String               @id
  runCrewId           String?
  title               String
  date                DateTime
  timezone            String?
  meetUpPoint         String
  meetUpPlaceId       String?
  meetUpLat           Float?
  meetUpLng           Float?
  totalMiles          Float?
  pace                String?
  stravaMapUrl        String?              // Public Strava route URL shown on the run page
  description         String?
  postRunActivity     String?              // Post-run activity (e.g. "light social at X", "coffee at Y")
  routePhotos         Json?                // Array of photo URLs: ["url1", "url2", ...]
  mapImageUrl         String?              // Single map image URL (snip from Strava or uploaded)
  staffNotes          String?              // Data entry note for approver (e.g. "Couldn't get Strava URL")
  // Source inputs - capture ALL available sources for AI processing and traceability
  stravaEventUrl      String?              // Optional Strava event URL for description context
  stravaText          String?              // Optional pasted Strava event description
  webUrl              String?              // Web/website URL
  webText             String?              // Raw text blob from web (copy/paste)
  igPostText          String?              // Instagram post text (copy/paste)
  igPostGraphic       String?              // Instagram post image URL (uploaded blob)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime
  startTimeHour       Int?
  startTimeMinute     Int?
  startTimePeriod     String?
  runClubId           String?
  athleteGeneratedId  String?
  staffGeneratedId    String?
  citySlug            String
  cityId              String?
  cities              cities?              @relation(fields: [cityId], references: [id], onDelete: SetNull)
  slug                String?              @unique // URL-friendly slug: "title-of-run" (generated from title)
  dayOfWeek           String?
  workflowStatus      RunWorkflowStatus    @default(DEVELOP)
  /// Public discoverability — independent of workflowStatus editorial pipeline.
  published           Boolean              @default(false)
  endPoint            String?
  meetUpStreetAddress String?
  meetUpCity          String?
  meetUpState         String?
  meetUpZip           String?
  routeNeighborhood String?              // Neighborhood/area route goes through (e.g. "Arlington Heights", "Back Bay") - gives run flavor
  runType             String?              // Type of run location: "track", "trail", "neighborhood", "park"
  workoutDescription  String?              // Workout focus/description (e.g. "emphasizes speed training for those want to increase threshold")
  directionsText        String?              // Staff pasted route directions — copies forward on series advance
  endStreetAddress    String?
  endCity             String?
  endState            String?
  runSeriesId         String?              // null = standalone; set = series occurrence (FK to run_series)
  /// Optional: tag this run to a race registry (training for X marathon, etc.).
  raceRegistryId      String?
  /// Idempotent key for Company → prod shakeout sync (one row per race_run_event window). Null for normal city_runs.
  shakeoutDedupeKey   String?              @unique
  locationId          String?              // FK to run_locations (auto-seeded or manually linked)
  routeId             String?              // Optional saved route (reference path + media)
  workoutId           String?              // Optional structured workout for join-my-workout
  /// Product behavior unlock: CLUB enables check-in, look-back, reminders.
  cityRunType         CityRunType          @default(OTHER)
  city_run_rsvps      city_run_rsvps[]
  city_run_messages   city_run_messages[]
  city_run_checkins   city_run_checkins[]
  city_run_activity_links city_run_activity_links[]
  Athlete             Athlete?             @relation(fields: [athleteGeneratedId], references: [id], onDelete: Cascade)
  run_crews           run_crews?           @relation(fields: [runCrewId], references: [id], onDelete: Cascade)
  runClub             run_clubs?           @relation(fields: [runClubId], references: [id], onDelete: SetNull)
  runSeries           run_series?          @relation(fields: [runSeriesId], references: [id], onDelete: SetNull)
  race_registry       race_registry?       @relation("CityRunRaceRegistry", fields: [raceRegistryId], references: [id], onDelete: SetNull)
  location            run_locations?       @relation(fields: [locationId], references: [id], onDelete: SetNull)
  route               routes?              @relation(fields: [routeId], references: [id], onDelete: SetNull)
  workout             workouts?            @relation(fields: [workoutId], references: [id], onDelete: SetNull)

  @@index([athleteGeneratedId])
  @@index([citySlug])
  @@index([cityId])
  @@index([slug])
  @@index([date])
  @@index([dayOfWeek])
  @@index([workflowStatus])
  @@index([runClubId])
  @@index([runCrewId])
  @@index([staffGeneratedId])
  @@index([runSeriesId])
  @@index([raceRegistryId])
  @@index([locationId])
  @@index([routeId])
  @@index([workoutId])
  @@index([cityRunType])
  // Table name is city_runs (migrated from run_crew_runs). Explicit map so deployed builds never use old name.
  @@map("city_runs")
}

/// Expo push token per device — app notification delivery endpoints only (not inbox content).
model athlete_appnotification_devices {
  id            String   @id @default(cuid())
  athleteId     String
  expoPushToken String   @unique
  platform      String?
  deviceId      String?
  enabled       Boolean  @default(true)
  lastSeenAt    DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  Athlete       Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@index([athleteId])
}

model run_series {
  id                  String               @id
  slug                String?              @unique // URL-friendly e.g. "dc-run-crew-tuesday" (club slug + day)
  dayOfWeek           String               // "MONDAY" | "TUESDAY" | ... | "SUNDAY" (canonical)
  runClubId           String?              // which club owns this recurring series
  name                String?              // series label, e.g. "Tuesday Tempo"
  description         String?              // series blurb — seeds each new occurrence's description
  seriesRunRawText    String?              // series-specific raw text (neighborhood, meetup details, etc.) — persisted
  citySlug            String?              // city slug (e.g. "dc", "arlington") — same for all occurrences
  cityId              String?
  cities              cities?              @relation(fields: [cityId], references: [id], onDelete: SetNull)
  meetUpPoint         String?              // canonical meeting location name (same corner every week)
  meetUpStreetAddress String?
  meetUpCity          String?
  meetUpState         String?
  meetUpPlaceId       String?
  meetUpLat           Float?
  meetUpLng           Float?
  runType             String?              // "track" | "trail" | "neighborhood" | "park" — seeds city_runs.runType
  totalMiles          Float?               // typical distance — seeds city_runs.totalMiles
  routeNeighborhood   String?              // route/area context — seeds city_runs.routeNeighborhood
  workoutDescription  String?              // workout focus — seeds city_runs.workoutDescription
  postRunActivity     String?              // post-run social — seeds city_runs.postRunActivity
  endPoint            String?              // end/finish location (null = same as meetUpPoint)
  endStreetAddress    String?
  endCity             String?
  endState            String?
  startTimeHour       Int?                 // canonical run time (same every week)
  startTimeMinute     Int?
  startTimePeriod     String?              // "AM" | "PM"
  startDate           DateTime?            // when this series began; null = from whenever
  endDate             DateTime?            // when this series ends; null = forever
  workflowStatus      RunWorkflowStatus    @default(DEVELOP)  // mirrors city_runs: DEVELOP → PENDING → SUBMITTED → APPROVED
  createdAt           DateTime             @default(now())
  updatedAt           DateTime
  city_runs           city_runs[]
  runClub             run_clubs?           @relation(fields: [runClubId], references: [id], onDelete: SetNull)

  @@index([runClubId])
  @@index([citySlug])
  @@index([cityId])
  @@index([dayOfWeek])
  @@index([workflowStatus])
  @@map("run_series")
}


model run_crew_specific_races {
  id             String        @id
  runCrewId      String
  raceRegistryId String
  createdAt      DateTime      @default(now())
  race_registry  race_registry @relation(fields: [raceRegistryId], references: [id], onDelete: Cascade)
  run_crews      run_crews     @relation(fields: [runCrewId], references: [id], onDelete: Cascade)

  @@unique([runCrewId, raceRegistryId])
}

model run_crews {
  id                      String                    @id
  name                    String
  description             String?
  joinCode                String                    @unique
  logo                    String?
  icon                    String?
  archivedAt              DateTime?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime
  messageTopics           Json?
  city                    String?
  ageMin                  Int?
  ageMax                  Int?
  primaryMeetUpPoint      String?
  primaryMeetUpAddress    String?
  primaryMeetUpPlaceId    String?
  primaryMeetUpLat        Float?
  primaryMeetUpLng        Float?
  gender                  Gender?
  state                   State?
  typicalRunMiles         Float?
  longRunMilesMin         Float?
  longRunMilesMax         Float?
  timePreference          TimePreference[]          @default([])
  purpose                 Purpose[]                 @default([])
  trainingForRace         String?
  trainingForDistance     TrainingForDistance[]     @default([])
  easyMilesPace           Int?
  crushingItPace          Int?
  handle                  String                    @unique
  join_codes              join_codes[]
  run_crew_announcements  run_crew_announcements[]
  run_crew_events         run_crew_events[]
  run_crew_memberships    run_crew_memberships[]
  run_crew_messages       run_crew_messages[]
  city_runs               city_runs[]
  run_crew_specific_races run_crew_specific_races[]
  race_registry           race_registry?            @relation(fields: [trainingForRace], references: [id])
}

/// Top-level generation preset (e.g. Elite Marathon, Basic, Marine Corps Marathon).
enum AthletePersonaCapability {
  NON_RUNNER
  BEGINNER
  RECREATIONAL
  COMPETITIVE
  ELITE
}

enum AthletePersonaDedication {
  LOW
  MODERATE
  HIGH
  ELITE
}

enum FitnessDelta {
  SMALL
  MODERATE
  LARGE
}

enum ProgressionAggressiveness {
  CONSERVATIVE
  MODERATE
  AMBITIOUS
}

enum TrainingPlanGoalKind {
  RACE
  TRAINING_BLOCK
}

/// Reusable athlete archetype — time-agnostic slug (e.g. new-5k-improve).
model training_plan_persona {
  id                  String                    @id @default(cuid())
  slug                String                    @unique
  title               String
  capability          AthletePersonaCapability?
  dedication          AthletePersonaDedication?
  personaGoalLabel    String?
  workoutFrequencyCap Int?
  intentSummary       String?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  goals   training_plan_goal[]
  presets training_plan_preset[]

  @@index([capability])
}

/// Bounded goal with time horizon — slug includes weeks (e.g. new-5k-improve-12w).
model training_plan_goal {
  id                        String                      @id @default(cuid())
  slug                      String                      @unique
  personaId                 String
  persona                   training_plan_persona       @relation(fields: [personaId], references: [id], onDelete: Restrict)
  targetDistanceLabel       String?
  objectiveOfPlan           String?
  planDurationWeeks         Int
  timeHorizonLabel          String?
  fitnessDelta              FitnessDelta?
  progressionAggressiveness ProgressionAggressiveness?
  intensityReasoning        String?
  goalKind                  TrainingPlanGoalKind?
  coachIntent               String?
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime                    @updatedAt

  presets training_plan_preset[]

  @@index([personaId])
  @@index([planDurationWeeks])
}

model training_plan_preset {
  id          String  @id @default(cuid())
  slug        String  @unique
  title       String
  description String?
  /// Shown to athletes on preset selection; internal notes stay in `description`.
  publicDescription String?
  /// Canonical distance label (e.g. "Marathon") from COMMON_RACE_DISTANCE_PRESETS; null = any distance.
  targetDistanceLabel String?

  personaId String?
  goalId    String?
  persona   training_plan_persona? @relation(fields: [personaId], references: [id], onDelete: SetNull)
  goal      training_plan_goal?    @relation(fields: [goalId], references: [id], onDelete: SetNull)

  /// Staff/coach free-text intent that drove preset design (AI or manual).
  coachIntent String?
  /// What this plan is trying to achieve, e.g. "First 5K finish" or "Marathon BQ attempt".
  objectiveOfPlan String?
  athletePersonaCapability AthletePersonaCapability?
  athletePersonaGoal String?
  athletePersonaDedication AthletePersonaDedication?
  /// Generation-useful overview: volume, composition, long-run / quality structure families.
  coachPlanOverview Json?
  /// Named pace keys → anchor + offset; catalogue segment paceKeys resolve through this at materialization.
  paceProfile Json?

  /// Long-run rotation block: one long run per week for this many consecutive weeks (LR1…LRn) before the pattern repeats; drives pool stepping and placement.
  cycleLen           Int    @default(4)
  minWeeklyMiles     Int    @default(40)
  maxWeeklyMiles     Int?
  baseMiles          Float
  peakMiles          Float
  taperMiles         Float
  tempoIdealDow      Int    @default(2)
  intervalIdealDow   Int    @default(4)
  longRunDefaultDow  Int    @default(6)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  longRunConfigId   String?
  longRunConfig     long_run_config?   @relation(fields: [longRunConfigId], references: [id], onDelete: SetNull)
  intervalsConfigId String?
  intervalsConfig   intervals_config?  @relation(fields: [intervalsConfigId], references: [id], onDelete: SetNull)
  tempoConfigId     String?
  tempoConfig       tempo_config?      @relation(fields: [tempoConfigId], references: [id], onDelete: SetNull)
  easyConfigId      String?
  easyConfig        easy_config?       @relation(fields: [easyConfigId], references: [id], onDelete: SetNull)
  /// JSON: standardMiles, minMiles, paceOffsetSecPerMile, weeklyTargetBufferMiles (easy-day defaults / pace vs 5K anchor)
  easyRunConfig     Json?
  training_plans  training_plans[]
  training_cohorts training_cohorts[]
}

/// Long-run rotation: cycle positions map to catalogue; many presets can share one.
model long_run_config {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  positions     long_run_config_position[]
  usedByPresets training_plan_preset[]

  @@index([name])
}

/// One long-run slot in the repeating cycle.
model long_run_config_position {
  id              String         @id @default(cuid())
  longRunConfigId String
  long_run_config long_run_config @relation(fields: [longRunConfigId], references: [id], onDelete: Cascade)

