// ─── RaceBuildTrainer ────────────────────────────────────────────────────────
//
// A training group anchored to a specific race. Members "bolt to" this group
// to train together for the event. Distinct from run_crews (organic/ongoing);
// this is race-first and time-bounded (ends at race date).
//
// Race data source: race_registry (product catalog). The companyRaceId links
// back to GoFastCompany's curated race content (races.id) for public page
// cross-referencing.

model race_trainer_groups {
  id             String                    @id @default(cuid())
  raceId         String                    // FK → race_registry (product catalog)
  companyRaceId  String?                   // Optional reference to GoFastCompany races.id
  name           String                    // e.g. "Training for Boston 2026"
  handle         String                    @unique  // URL-safe slug
  description    String?
  logo           String?
  joinCode       String                    @unique
  city           String?
  state          String?
  isActive       Boolean                   @default(true)
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  race_registry          race_registry              @relation(fields: [raceId], references: [id])
  race_trainer_members   race_trainer_members[]

  @@index([raceId])
  @@index([companyRaceId])
  @@map("race_trainer_groups")
}

model race_trainer_members {
  id             String                    @id @default(cuid())
  groupId        String
  userId         String                    // FK → users (app user)
  role           RaceTrainerRole           @default(MEMBER)
  joinedAt       DateTime                  @default(now())

  race_trainer_groups    race_trainer_groups        @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
  @@map("race_trainer_members")
}

enum RaceTrainerRole {
  MEMBER
  PACER
  COACH
  ADMIN
}

// Route/location catalogue. Created manually or auto-seeded from run meetUpPoint/title.
// Raw on creation (just name + gofastCity); attributes filled in over time.
model run_locations {
  id          String         @id @default(cuid())
  gofastCity  String                               // "dc", "arlington" — same slug pattern as city_runs
  name        String                               // "Haines Point", "Custis Trail"
  slug        String         @unique               // auto-generated from name
  runType     String?                              // "park" | "track" | "trail" | "neighborhood"
  shape       RouteShape?
  terrain     RouteTerrain?
  surface     RouteSurface?
  traffic     RouteTraffic?
  lighting    RouteLighting?
  shade       RouteShade?
  vibes       RouteVibe[]    @default([])          // SPEED_WORK, TEMPO, LONG_RUN, etc.
  loopMiles   Float?                               // distance of one loop/segment
  notes       String?                              // editorial: "Fast flat loop. No cars. Speed work venue."
  stravaUrl   String?
  meetUpPoint String?                              // default start/meet-up description
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  city_runs   city_runs[]

  @@index([gofastCity])
  @@index([slug])
  @@map("run_locations")
}
