{
  "name": "gofast-nextapp",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "preprisma:generate": "node -e \"const fs=require('fs'); const p='node_modules/.prisma'; try{fs.rmSync(p,{recursive:true,force:true})}catch(e){}\"",
    "build": "prisma migrate deploy --schema=./prisma/schema.prisma && npm run preprisma:generate && prisma generate --schema=./prisma/schema.prisma && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate --schema=./prisma/schema.prisma",
    "prisma:generate": "prisma generate --schema=./prisma/schema.prisma",
    "prisma:migrate": "prisma migrate deploy --schema=./prisma/schema.prisma",
    "db:generate": "prisma generate --schema=./prisma/schema.prisma",
    "db:push": "prisma db push --schema=./prisma/schema.prisma",
    "db:studio": "prisma studio --schema=./prisma/schema.prisma",
    "db:upsert-company": "tsx scripts/upsert-company.ts",
    "db:init-company": "tsx scripts/init-company.ts",
    "db:setup-company": "tsx scripts/setup-company.ts",
    "db:backfill-athletes": "tsx scripts/backfill-athlete-company.ts",
    "db:check-athletes": "tsx scripts/check-athletes.ts",
    "db:verify-schema": "tsx scripts/verify-schema.ts",
    "db:populate-bidirectional-ids": "tsx scripts/populate-bidirectional-run-club-ids.ts",
    "db:seed-demo-races": "tsx scripts/seed-demo-races.ts",
    "smoke:fivek-pace": "tsx scripts/smoke-fivek-pace.ts",
    "smoke:garmin-minimal": "tsx scripts/garmin-minimal-workout-smoke.ts",
    "db:migrate-pace-targets": "tsx scripts/migrate-legacy-pace-targets.ts",
    "db:fix-monday-race-totalweeks": "tsx scripts/fix-monday-race-totalweeks.ts",
    "verify:race-load-followups": "tsx scripts/verify-race-load-followups.ts"
  },
  "dependencies": {
    "@gofast/shared-db": "file:./packages/shared-db",
    "@prisma/client": "6.16.3",
    "@vercel/blob": "^2.0.0",
    "@vercel/functions": "^3.4.3",
    "axios": "^1.9.0",
    "firebase": "^10.7.1",
    "firebase-admin": "^12.7.0",
    "lucide-react": "^0.555.0",
    "next": "15.4.8",
    "react": "19.2.1",
    "react-dom": "19.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "pg": "^8.19.0",
    "postcss": "^8.4.47",
    "prisma": "6.16.3",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.20.6",
    "typescript": "^5.5.3"
  }
}
