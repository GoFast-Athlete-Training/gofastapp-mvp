# Copy to .env.local — never commit secrets

# Public athlete card (GoFast Page): runner subdomain root, no trailing slash.
# Profile hub links and preview “open live” use this; defaults to https://runner.gofastcrushgoals.com if unset.
NEXT_PUBLIC_RUNNER_PHOTO_URL=https://runner.gofastcrushgoals.com

# Runner app URL for signup/gorun links in GoFast Page previews; defaults to https://app.gofastcrushgoals.com if unset.
# NEXT_PUBLIC_GOFAST_APP_URL=https://app.gofastcrushgoals.com

# Public race catalog (gofast-contentpublic). Race hub “Full race info” links here: {URL}/race/{slug}
# NEXT_PUBLIC_CONTENT_PUBLIC_URL=https://races.gofastcrushgoals.com

# Pooled (Neon “pooler” host). Append for serverless + pgBouncer:
# ?pgbouncer=true&connection_limit=1&pool_timeout=30
DATABASE_URL="postgresql://..."

# Non-pooled Neon connection (no “-pooler” in host). Required for prisma migrate; runtime uses DATABASE_URL only.
# If you do not use a pooler, set this equal to DATABASE_URL.
DIRECT_DATABASE_URL="postgresql://..."

# Garmin OAuth2 (single app for wellness + training-api — PKCE connect, token exchange, refresh)
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=

# When true: push-to-garmin error JSON includes rawBody + tokenSummary (JWT claims).
# GARMIN_DEBUG=true

# Server-to-server: GoFastCompany training-engine dashboard → these routes require the same secret on both apps.
# Header: x-gofast-training-engine-secret
GOFAST_TRAINING_ENGINE_SECRET=

# Server-to-server: GoFastCompany staff race hub announcements → MVP internal routes.
# Header: x-gofast-internal-secret (or Authorization: Bearer <same value>)
GOFAST_INTERNAL_RACE_HUB_SECRET=
# Athlete id in this DB used as author for staff-created hub announcements (sentinel/service account row must exist).
RACE_HUB_STAFF_AUTHOR_ATHLETE_ID=
