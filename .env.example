# Copy to .env.local — never commit secrets

DATABASE_URL="postgresql://..."

# Production Garmin OAuth (token refresh)
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=

# Garmin test app OAuth (separate callback; writes only Athlete.garmin_test_* — never prod tokens)
GARMIN_TEST_CLIENT_ID=
GARMIN_TEST_CLIENT_SECRET=
# Optional: stored on athlete as garmin_test_linked_email after test OAuth (e.g. adam@gofastcrushgoals.com)
# GARMIN_TEST_LINKED_ACCOUNT_EMAIL=

# Garmin Training API auth mode: bearer (default) or oauth1
GARMIN_TRAINING_AUTH_MODE=bearer
# OAuth1 mode only:
# GARMIN_TRAINING_OAUTH_CONSUMER_KEY=
# GARMIN_TRAINING_OAUTH_CONSUMER_SECRET=
# GARMIN_TRAINING_OAUTH_TOKEN_SECRET=

# Optional: Garmin sandbox / evaluation training API (see docs/GARMIN_TRAINING_TEST_ENV.md)
# Used by scripts/set-test-garmin-token.ts to populate Athlete.garmin_test_* fields
GARMIN_TRAINING_TEST_ACCESS_TOKEN=
GARMIN_TRAINING_TEST_USER_ID=
# GARMIN_TRAINING_TEST_ATHLETE_ID=
# GARMIN_TRAINING_TEST_ATHLETE_EMAIL=
