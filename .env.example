# Copy to .env.local — never commit secrets

DATABASE_URL="postgresql://..."

# Production Garmin OAuth (token refresh)
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=

# Optional: Garmin sandbox / evaluation training API (see docs/GARMIN_TRAINING_TEST_ENV.md)
# Used by scripts/set-test-garmin-token.ts to populate Athlete.garmin_test_* fields
GARMIN_TRAINING_TEST_ACCESS_TOKEN=
GARMIN_TRAINING_TEST_USER_ID=
# GARMIN_TRAINING_TEST_ATHLETE_ID=
# GARMIN_TRAINING_TEST_ATHLETE_EMAIL=
