# Copy to .env.local -- never commit secrets

# Public athlete card (GoFast Page): runner subdomain root, no trailing slash.
# Profile hub links and preview "open live" use this; defaults to https://runner.gofastcrushgoals.com if unset.
NEXT_PUBLIC_RUNNER_PHOTO_URL=https://runner.gofastcrushgoals.com

# Runner app URL for signup/gorun links in GoFast Page previews; defaults to https://app.gofastcrushgoals.com if unset.
# NEXT_PUBLIC_GOFAST_APP_URL=https://app.gofastcrushgoals.com

# Public race catalog (gofast-contentpublic). Race hub "Full race info" links here: {URL}/race/{slug}
# NEXT_PUBLIC_CONTENT_PUBLIC_URL=https://races.gofastcrushgoals.com

# Pooled Neon connection -- used by Prisma at runtime in all serverless environments.
# Must use the "-pooler" host. Three params are required to prevent cold-start hangs:
#   pgbouncer=true     -- disables prepared statements (required for PgBouncer transaction mode)
#   connection_limit=1 -- prevents connection exhaustion across serverless function instances
#   connect_timeout=15 -- gives cold Neon compute time to wake before Prisma gives up (prevents silent webhook failures)
#
# In Vercel (Vercel Postgres integration): copy the value of POSTGRES_PRISMA_URL and append &connection_limit=1
# Format: postgresql://USER:PASS@ep-xxx-pooler.REGION.aws.neon.tech/DBNAME?pgbouncer=true&connection_limit=1&connect_timeout=15&sslmode=require
DATABASE_URL="postgresql://USER:PASS@ep-xxx-pooler.REGION.aws.neon.tech/DBNAME?pgbouncer=true&connection_limit=1&connect_timeout=15&sslmode=require"

# Non-pooled Neon connection -- no "-pooler" in host. Used ONLY for prisma migrate (directUrl in schema.prisma).
# Runtime queries use DATABASE_URL (pooled) above. Never set this to the pooler URL.
# In Vercel: set DIRECT_DATABASE_URL (name must match). Use Neon unpooled URL (same string as DATABASE_URL_UNPOOLED if linked).
# Format: postgresql://USER:PASS@ep-xxx.REGION.aws.neon.tech/DBNAME?sslmode=require
DIRECT_DATABASE_URL="postgresql://USER:PASS@ep-xxx.REGION.aws.neon.tech/DBNAME?sslmode=require"

# Garmin OAuth2 (single app for wellness + training-api -- PKCE connect, token exchange, refresh)
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=

# When true: push-to-garmin error JSON includes rawBody + tokenSummary (JWT claims).
# GARMIN_DEBUG=true

# Server-to-server: GoFastCompany training-engine dashboard -> these routes require the same secret on both apps.
# Header: x-gofast-training-engine-secret
GOFAST_TRAINING_ENGINE_SECRET=

# Server-to-server: GoFastCompany staff race hub announcements -> MVP internal routes.
# Header: x-gofast-internal-secret (or Authorization: Bearer <same value>)
GOFAST_INTERNAL_RACE_HUB_SECRET=
# Athlete id in this DB used as author for staff-created hub announcements (sentinel/service account row must exist).
RACE_HUB_STAFF_AUTHOR_ATHLETE_ID=
